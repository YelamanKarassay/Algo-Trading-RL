<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ config.name }} report</title>
  <style>
    :root {
      color-scheme: light;
      --ink: #18212f;
      --muted: #64748b;
      --line: #d7dee8;
      --soft: #f6f8fb;
      --panel: #ffffff;
      --accent: #1f7a68;
      --accent-2: #315f8c;
      --warn: #a23b3b;
      --shadow: 0 16px 40px rgba(22, 34, 51, 0.08);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      background: #edf1f5;
      color: var(--ink);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.5;
    }

    .shell {
      max-width: 1220px;
      margin: 0 auto;
      padding: 32px 22px 48px;
    }

    .hero {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 14px;
      box-shadow: var(--shadow);
      padding: 30px;
    }

    .eyebrow {
      color: var(--accent);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    h1 {
      margin: 6px 0 8px;
      font-size: 34px;
      line-height: 1.1;
      letter-spacing: 0;
    }

    h2 {
      margin: 0 0 14px;
      font-size: 19px;
      letter-spacing: 0;
    }

    p { margin: 0; }

    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 18px;
    }

    .pill {
      border: 1px solid var(--line);
      border-radius: 999px;
      color: var(--muted);
      background: #f9fbfd;
      padding: 6px 11px;
      font-size: 13px;
      white-space: nowrap;
    }

    .kpis {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      margin-top: 22px;
    }

    .kpi {
      background: var(--soft);
      border: 1px solid var(--line);
      border-radius: 10px;
      padding: 16px;
    }

    .kpi .label {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .kpi .value {
      margin-top: 8px;
      font-size: 24px;
      font-weight: 760;
    }

    .kpi .detail {
      margin-top: 4px;
      color: var(--muted);
      font-size: 13px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 18px;
      margin-top: 18px;
    }

    .panel {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 12px;
      box-shadow: var(--shadow);
      padding: 20px;
    }

    .span-12 { grid-column: span 12; }
    .span-8 { grid-column: span 8; }
    .span-6 { grid-column: span 6; }
    .span-4 { grid-column: span 4; }

    .chart {
      display: block;
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: #fff;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      overflow: hidden;
      font-size: 14px;
    }

    th {
      color: var(--muted);
      background: #f7f9fc;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    th, td {
      border-bottom: 1px solid var(--line);
      padding: 11px 10px;
      text-align: right;
      vertical-align: top;
    }

    th:first-child, td:first-child { text-align: left; }
    tbody tr:last-child td { border-bottom: 0; }

    .agent-main {
      color: var(--accent);
      font-weight: 760;
    }

    .positive { color: #18745f; }
    .negative { color: var(--warn); }
    .muted { color: var(--muted); }

    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .note {
      color: var(--muted);
      font-size: 14px;
    }

    details {
      margin-top: 14px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: #fbfcfe;
    }

    summary {
      cursor: pointer;
      padding: 12px 14px;
      color: var(--accent-2);
      font-weight: 700;
    }

    pre {
      margin: 0;
      padding: 0 14px 14px;
      overflow: auto;
      white-space: pre;
      color: #2b3545;
      font-size: 12px;
    }

    @media (max-width: 920px) {
      .kpis { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .span-8, .span-6, .span-4 { grid-column: span 12; }
      .two-col { grid-template-columns: 1fr; }
    }

    @media (max-width: 560px) {
      .shell { padding: 18px 12px 32px; }
      .hero { padding: 20px; }
      h1 { font-size: 27px; }
      .kpis { grid-template-columns: 1fr; }
      table { font-size: 12px; }
      th, td { padding: 8px 6px; }
    }
  </style>
</head>
<body>
  <main class="shell">
    <header class="hero">
      <div class="eyebrow">Quantphemes RL Diagnostics</div>
      <h1>{{ config.name }}</h1>
      <p class="note">{{ config.description }}</p>
      <div class="meta">
        <span class="pill">Symbol {{ config.data.symbol }}</span>
        <span class="pill">{{ data_period }}</span>
        <span class="pill">{{ decision_count }} decisions/day</span>
        <span class="pill">Force close {{ config.market.force_close_time }} HK</span>
        <span class="pill">Agent {{ config.agent.type }}</span>
      </div>
      <div class="kpis">
        {% for stat in hero_stats %}
        <div class="kpi">
          <div class="label">{{ stat.label }}</div>
          <div class="value">{{ stat.value }}</div>
          <div class="detail">{{ stat.detail }}</div>
        </div>
        {% endfor %}
      </div>
      <details>
        <summary>Config Snapshot</summary>
        <pre>{{ config_yaml }}</pre>
      </details>
    </header>

    <section class="grid">
      <div class="panel span-12">
        <h2>Performance Summary</h2>
        <table>
          <thead>
            <tr>
              <th>Agent</th>
              <th>Final NAV</th>
              <th>Return</th>
              <th>Sharpe</th>
              <th>Trades</th>
              <th>Fees</th>
              <th>Alpha vs B&H</th>
            </tr>
          </thead>
          <tbody>
          {% for row in summary_rows %}
            <tr>
              <td class="{% if row.agent == 'main' %}agent-main{% endif %}">{{ row.agent }}</td>
              <td>{{ row.final_nav|money }}</td>
              <td class="{% if row["return"] > 0 %}positive{% elif row["return"] < 0 %}negative{% endif %}">
                {{ row["return"]|pct }}
              </td>
              <td>{{ row.sharpe|number(3) }}</td>
              <td>{{ row.num_trades }}</td>
              <td>{% if row.total_fees != "" %}{{ row.total_fees|money }}{% endif %}</td>
              <td>
                {% if row.alpha_vs_bh != "" %}
                  <span class="{% if row.alpha_vs_bh > 0 %}positive{% elif row.alpha_vs_bh < 0 %}negative{% endif %}">
                    {{ row.alpha_vs_bh|pct }}
                  </span>
                {% endif %}
              </td>
            </tr>
          {% endfor %}
          </tbody>
        </table>
      </div>

      <div class="panel span-8">
        <h2>NAV Curves</h2>
        <img class="chart" alt="NAV curves" src="data:image/png;base64,{{ nav_curve_png }}">
      </div>

      <div class="panel span-4">
        <h2>Cost Pressure</h2>
        <p class="note">Fees as a fraction of absolute gross PnL.</p>
        <div class="kpi" style="margin-top: 14px;">
          <div class="label">Fee Load</div>
          <div class="value">{{ fee_fraction|pct }}</div>
          <div class="detail">Lower is better for frequent trading.</div>
        </div>
        <div class="kpi" style="margin-top: 12px;">
          <div class="label">Oracle</div>
          {% if oracle %}
            <div class="value">{{ oracle.final_nav|money }}</div>
            <div class="detail">Oracle final NAV; return {{ oracle.return|pct }}</div>
          {% else %}
            <div class="value muted">Disabled</div>
            <div class="detail">Oracle disabled for this run.</div>
          {% endif %}
        </div>
      </div>

      <div class="panel span-6">
        <h2>Action Distribution</h2>
        <img class="chart" alt="Action distribution" src="data:image/png;base64,{{ action_dist_png }}">
      </div>

      <div class="panel span-6">
        <h2>Reward Histogram</h2>
        <img class="chart" alt="Reward histogram" src="data:image/png;base64,{{ reward_hist_png }}">
      </div>

      <div class="panel span-12">
        <h2>State Coverage Heatmap</h2>
        <p class="note">
          Visited cells: {{ coverage_summary.pct_visited|pct }};
          well-visited cells: {{ coverage_summary.pct_well_visited|pct }}.
        </p>
        <img class="chart" alt="State coverage heatmap" src="data:image/png;base64,{{ coverage_png }}">
      </div>

      <div class="panel span-12">
        <h2>Feature Signal Check</h2>
        <table>
          <thead>
            <tr>
              <th>Feature</th>
              <th>Bin</th>
              <th>Mean Return</th>
              <th>Std Return</th>
              <th>Mutual Info</th>
            </tr>
          </thead>
          <tbody>
          {% for row in signal_rows %}
            <tr>
              <td>{{ row.feature }}</td>
              <td>{{ row.bin }}</td>
              <td class="{% if row.mean_return > 0 %}positive{% elif row.mean_return < 0 %}negative{% endif %}">
                {{ row.mean_return|number(8) }}
              </td>
              <td>{{ row.std_return|number(8) }}</td>
              <td>{{ row.mi|number(8) }}</td>
            </tr>
          {% endfor %}
          </tbody>
        </table>
      </div>
    </section>
  </main>
</body>
</html>
